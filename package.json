{
  "name": "@nativescript-forge/cli",
  "version": "1.0.10",
  "description": "NativeScript Forge in your terminal, an opinionated interactive wrapper around the NativeScript CLI",
  "main": "dist/index.js",
  "files": [
    "dist",
    "bin"
  ],
  "bin": {
    "nsf": "bin/nsf"
  },
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepublishOnly": "npm run lint && npm run build"
  },
  "dependencies": {},
  "devDependencies": {
    "@clack/prompts": "^0.7.0",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "commander": "^11.1.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "picocolors": "^1.0.0",
    "prettier": "^3.2.4",
    "ts-node": "^10.9.2",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nativescript-forge/cli.git"
  },
  "keywords": [
    "nativescript",
    "forge",
    "cli"
  ],
  "author": "Kang Cahya",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/nativescript-forge/cli/issues"
  },
  "homepage": "https://github.com/nativescript-forge/cli#readme"
}
